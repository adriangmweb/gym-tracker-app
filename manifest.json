            "icons": [{ "src": "icons/icon-192x192.svg", "sizes": "192x192", "type": "image/svg+xml" }]
        },
        {
            "name": "Export data",
            "short_name": "Export",
            "description": "Export your data",
            "url": "/#export-data",
            "icons": [{ "src": "icons/icon-192x192.svg", "sizes": "192x192", "type": "image/svg+xml" }]
